//weird sol1

class Solution {
public:
    int minCostClimbingStairs(vector<int>& cost) {
        int n=cost.size();
        for(int i=2;i<n;i++){
            cost[i]+=min(cost[i-1],cost[i-2]);
        }
        return min(cost[n-1],cost[n-2]);
    }
};

//striver method
class Solution {
public:
    int minCostClimbingStairs(vector<int>& cost) {
        int n=cost.size();
        int prev1=cost[0],prev2=cost[1];
        //genius edgecase
        if(n==2){
            return min(prev1,prev2);
        }

        for(int i=2;i<n;i++){
            int curr=cost[i]+min(prev1,prev2);
            prev1=prev2;
            prev2=curr;
        }
        return min(prev1,prev2);
    }
};
