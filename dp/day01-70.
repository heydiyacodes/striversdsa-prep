class Solution {
public:
    int climbStairs(int n) {
        //use fibonacci seq
        if(n==0||n==1) return 1;

        // vector<int> dp(n+1);
        // dp[0]=dp[1]=1;

        // for(int i=2;i<=n;i++){
        //     dp[i]=dp[i-1]+dp[i-2];
        // }
        // return dp[n]
      
        //space optimization
        int prev=1,curr=1;
        for(int i=2;i<=n;i++){
            int temp=curr;
            curr=prev+curr;
            prev=temp;
        }
        return curr;
    }
};
